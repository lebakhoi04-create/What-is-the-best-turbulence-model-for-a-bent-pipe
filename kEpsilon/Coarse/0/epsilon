FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 9.3;

boundaryField
{
    inlet
    {
        type        timeVaryingMappedFixedValue;
        setAverage  false;
        offset      0;
        value       uniform 1;
    }

    outlet
    {
        type            zeroGradient;
    }

    wall
    {
        type            epsilonWallFunction;
        value           uniform 9.3;
    }
}


