FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 30.6;

boundaryField
{
    inlet
    {
        type        timeVaryingMappedFixedValue;
        setAverage  false;
        offset      0;
        value       uniform 1;
    }
    outlet
    {
        type            zeroGradient;
    }

    wall
    {
        type            omegaWallFunction;
        value           uniform 30;
    }
}


