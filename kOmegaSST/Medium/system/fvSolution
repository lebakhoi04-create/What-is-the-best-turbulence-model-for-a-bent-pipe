FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-06;
        relTol          0.1;
        smoother        DIC;
    }

    "(U|k|omega)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-07;
        relTol          0.1;
    }

    Phi                         // keep if running potentialFoam init
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-06;
        relTol          0.01;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors    1;      // 1 is fine for good quality mesh

    residualControl                     // auto-stop when converged
    {
        p               1e-05;
        U               1e-05;
        "(k|omega)"     1e-05;
    }
}

relaxationFactors
{
    fields
    {
        p               0.3;            // pressure field relaxation — critical for SIMPLE
    }
    equations
    {
        U               0.7;
        k               0.7;
        omega           0.7;
    }
}
