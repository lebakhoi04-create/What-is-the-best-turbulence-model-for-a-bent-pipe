FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.303;

boundaryField
{
    wall
    {
        type            kLowReWallFunction;
        value           uniform 0;
    }
    inlet
    {
        type            cyclicAMI;
        value           uniform 0.1;
    }
    outlet
    {
        type            cyclicAMI;
        value           uniform 0.1;
    }
}


