FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 8.98);

boundaryField
{
    wall
    {
        type            noSlip;
    }
    inlet
    {
        type            cyclicAMI;
        value           uniform (0 0 8.98);
    }
    outlet
    {
        type            cyclicAMI;
        value           uniform (0 0 8.98);
    }
}

