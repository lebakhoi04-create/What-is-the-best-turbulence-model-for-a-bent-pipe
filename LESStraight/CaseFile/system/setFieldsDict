FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
defaultFieldValues
(
    volVectorFieldValue U (0.0 0.0 8.98)
);

regions
(
    boxToCell
    {
        box (0.0 0.0 -1.0) (1.0 1.0 1.0); 
        fieldValues
        (
            volVectorFieldValue U (0.5 0.5 9.5)
        );
    }
    
    boxToCell
    {
        box (-1.0 -1.0 -1.0) (0.0 0.0 1.0);
        fieldValues
        (
            volVectorFieldValue U (-0.5 -0.5 8.5)
        );
    }
);

